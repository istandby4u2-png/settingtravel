# 공개 URL (OG·metadataBase). 프로덕션에서는 반드시 설정하세요.
# 예: https://www.istandby4u2.com
NEXT_PUBLIC_SITE_URL=

# FastAPI 백엔드가 별도 호스트일 때 (비우면 같은 출처의 /api + 개발 시 프록시)
# NEXT_PUBLIC_API_URL=https://api.istandby4u2.com

# 로컬에서만: NEXT_PUBLIC_API_URL 없이 /api를 쓸 때 프록시 대상 (기본 http://127.0.0.1:8000)
# BACKEND_PROXY_URL=http://127.0.0.1:8000
